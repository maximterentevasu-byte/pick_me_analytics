{
  "name": "tg-weekly-metrics",
  "version": "1.0.0",
  "description": "Weekly Telegram channel metrics collector for Railway + Google Sheets",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "session": "node scripts/generate-session.js",
    "run-once": "RUN_ONCE=true node src/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "googleapis": "^140.0.1",
    "input": "^1.0.1",
    "luxon": "^3.5.0",
    "node-cron": "^3.0.3",
    "telegram": "^2.26.22"
  }
}
